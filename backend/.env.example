# Main Telegram bot service for the shared Railway setup.
# This service owns /start, the webhook, and the launcher buttons.
TELEGRAM_BOT_TOKEN=your_profile_bot_token_here
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSL=true
BASE_URL=https://your-profile-bot-url.railway.app
REGISTER_WEBHOOK=true
PORT=8080

# URLs of the three Mini Apps used in /start
APP_IMAGE_URL=https://your-image-bot-url.railway.app
APP_VIDEO_URL=https://your-video-bot-url.railway.app
APP_PROFILE_URL=https://your-profile-bot-url.railway.app
